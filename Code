  .marquee-track {
    display: flex;
    gap: 3rem;
    animation: marquee 20s linear infinite;
    width: max-content;
  }
  .marquee-item {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-style: italic;
