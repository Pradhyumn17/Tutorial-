    letter-spacing: 0.1em;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 3rem;
  }
  .marquee-item::after {
    content: '✦';
    color: var(--gold);
    font-size: 0.5rem;
    font-style: normal;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* 3D tilt card effect */
  .tilt-card {
    transform-style: preserve-3d;
    transform: perspective(1000px);
  }

  /* Gradient shimmer on hover */
  @keyframes shimmer {
