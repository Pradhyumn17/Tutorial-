<script>
// ─── LOADER ───
let progress = 0;
const loaderPct = document.getElementById('loader-pct');
const loader = document.getElementById('loader');
const interval = setInterval(() => {
  progress += Math.random() * 15;
  if (progress >= 100) {
    progress = 100;
