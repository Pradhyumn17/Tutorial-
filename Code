// ─── MAIN VIDEO CONTROLS ───
// (Uses placeholder UI since no actual video src is set by default)
const reelContainer = document.getElementById('main-reel');
const mainPlayBtn = document.getElementById('main-play-btn');
const playPauseBtn = document.getElementById('play-pause-btn');
const progressFill = document.getElementById('progress-fill');
const progressBar = document.getElementById('progress-bar');
const timeDisplay = document.getElementById('time-display');
const volSlider = document.getElementById('vol-slider');
const fullscreenBtn = document.getElementById('fullscreen-btn');

// Demo progress animation for placeholder
let demoProgress = 0;
let demoPlaying = false;
let demoTimer;
let demoTotal = 180; // fake 3min

mainPlayBtn.addEventListener('click', toggleDemo);
playPauseBtn.addEventListener('click', toggleDemo);
reelContainer.addEventListener('click', e => {
  if (e.target === reelContainer || e.target.closest('.reel-placeholder')) toggleDemo();
});

function formatTime(sec) {
  const m = Math.floor(sec/60), s = Math.floor(sec%60);
  return `${m}:${s.toString().padStart(2,'0')}`;
}

function toggleDemo() {
  demoPlaying = !demoPlaying;
  if (demoPlaying) {
    reelContainer.classList.add('playing');
    playPauseBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>`;
    demoTimer = setInterval(() => {
      if (demoProgress >= demoTotal) { demoProgress = 0; }
      demoProgress += 0.5;
      const pct = (demoProgress / demoTotal) * 100;
      progressFill.style.width = pct + '%';
      timeDisplay.textContent = `${formatTime(demoProgress)} / ${formatTime(demoTotal)}`;
    }, 500);
  } else {
    reelContainer.classList.remove('playing');
    playPauseBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3L19 12L5 21V3Z"/></svg>`;
    clearInterval(demoTimer);
  }
}

progressBar.addEventListener('click', e => {
  const rect = progressBar.getBoundingClientRect();
  const pct = (e.clientX - rect.left) / rect.width;
  demoProgress = pct * demoTotal;
  progressFill.style.width = (pct*100) + '%';
  timeDisplay.textContent = `${formatTime(demoProgress)} / ${formatTime(demoTotal)}`;
});

fullscreenBtn.addEventListener('click', () => {
  if (!document.fullscreenElement) {
    reelContainer.requestFullscreen && reelContainer.requestFullscreen();
  } else {
    document.exitFullscreen && document.exitFullscreen();
  }
});

// ─── 3D TILT ON PORTFOLIO ITEMS ───
document.querySelectorAll('.tilt-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width - 0.5;
    const y = (e.clientY - rect.top) / rect.height - 0.5;
    card.style.transform = `perspective(800px) rotateY(${x*8}deg) rotateX(${-y*8}deg) scale(1.02)`;
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = 'perspective(800px) rotateY(0) rotateX(0) scale(1)';
  });
});

// ─── SMOOTH NAV LINKS ───
